# .env.example — copy to .env, never commit .env

# ── Required ──────────────────────────────────────────────────────────────────
SNS_TOPIC=arn:aws:sns:us-east-1:833090513377:orders-notifications-dev
WS_ENDPOINT=https://6zvolh5t5b.execute-api.us-east-1.amazonaws.com/prod
TABLE_ORDER=OrderTable

# ── Optional (features disabled if blank) ────────────────────────────────────
WS_CONNECTIONS_TABLE=ConnectionTable-dev
